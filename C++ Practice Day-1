  #include <iostream>
using namespace std;


//Write a program to find the largest of three numbers.
int main(){
    int a,b,c;
    cout<<"Enter the value a,b,c:"<<endl;
    cin>>a>>b>>c;
    
    if (a>=b && a>=c){
        cout<<"a is largest num:"<<a<<endl;
    }
    else if (b>=a && b>=c){
        cout<<"b is largest num:"<<b<<endl;
    }
    else{
        cout<<"c is largest num:"<<c<<endl;
    }
    return 0;
}

