#include <iostream>
#include <map>
using namespace std;

int main(){
    int arr[]={1,2,1,3,2,1};
    map<int, int>freq;
    for(int i=0; i<6; i++){
        freq[arr[i]]++;
    }
    for(auto x : freq){
        cout<< x.first<< " -> "<<x.second<<endl;
    }

    return 0;
}

