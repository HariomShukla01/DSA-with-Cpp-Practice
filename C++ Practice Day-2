#include <iostream>
using namespace std;
//Write a program to print the sum of n elements.

int main(){
    int n;
    cout<<"Enter the Value n:";
    cin>>n;
    int sum=0;

    for( int i=1; i<=n; i++){
        cout<<i<<endl;
        sum=sum+i;
    }
    cout<<" TotalSum: "<<sum;
    return 0;
}

