#include <iostream>
using namespace std;
//Write a program to print the count digit of n elements.
int main(){
    int n;
    cout<<"Enter the Value n:";
    cin>>n;
    int count=0;

    for( int i=1; i<=n; i++){
        count++;
    }
    cout<<" Total Count: "<<count;
    return 0;
}

