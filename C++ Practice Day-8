#include <iostream>
using namespace std;

//linear search in array

int main(){

    int arr[5] ={10,20,30,40,50};
    int target=40;
    bool found=false;

    for(int i=0; i<5; i++){
        if(arr[i]==target){
            found=true;
            break;
        }
    }

    if (found){
        cout<<"Element Founded:"<<endl;
    }
    else{
        cout<<"element Not Founded:"<<endl;
    }

    return 0;
}

