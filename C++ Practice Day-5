#include <iostream>
using namespace std;

//recursive function to find the nth Fibonacci number

int fib(int n ){
    if(n==0)
    return 0;

    if(n==1)
    return 1;

    return fib(n-1)+(n-2);
}



int main(){
cout<< fib(6);

return 0;
}

