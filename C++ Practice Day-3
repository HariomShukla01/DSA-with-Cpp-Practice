#include <iostream>
using namespace std;

// Function to find the maximum element in an array

int main(){
    int arr[5]={40,60,90,300,400};
    int max=arr[0];
    for(int i=0; i<5; i++){
        cout<<arr[i]<<endl;
        if(arr[i]>max){
            max=arr[i];
        }
    }
    cout<<"The maximum element in the array is:"<<max<<endl;
    return 0;
}

