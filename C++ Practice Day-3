#include <iostream>
using namespace std;

// Function to calculate the sum of elements in an array

int calculateSum(int arr[], int size){
    int sum = 0;
    for(int i=0; i<size; i++){
        sum = sum + arr[i];
    }
    return sum;
}

int main(){
    int arr[5]={1,2,3,4,5};
    int sum=0;
    for(int i=0; i<5; i++){
        cout<<arr[i]<<endl;
        sum=sum+arr[i];
    }
    cout<<"The sum of array is:"<<sum<<endl;
    return 0;
}

